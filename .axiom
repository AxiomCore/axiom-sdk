{"endpoints":[{"cache_policy":{"strategy":"stale_while_revalidate","ttlSeconds":300},"id":0,"method":"GET","name":"get_user","path":"/users/{user_id}","retry_policy":{"backoff":{"initialDelay":"500ms","maxDelay":"30s","multiplier":2,"type":"exponential","useJitter":true},"maxAttempts":5,"retryOnCodes":[502,503,504],"retryOnTimeout":true},"return_type":{"kind":"named","value":"User"},"validation_enabled":true},{"cache_policy":null,"id":1,"method":"POST","name":"create_user","path":"/users","retry_policy":null,"return_type":{"kind":"named","value":"User"},"validation_enabled":true}],"header":{"axiom_version":"1.0","min_runtime_version":1},"ir":{"endpoints":[{"doc":null,"id":0,"isStream":false,"method":"GET","name":"get_user","parameters":[{"isOptional":false,"name":"user_id","source":"path","typeRef":{"kind":"int64"}}],"path":"/users/{user_id}","returnIsOptional":false,"returnType":{"kind":"named","value":"User"}},{"doc":null,"id":1,"isStream":false,"method":"POST","name":"create_user","parameters":[{"isOptional":false,"name":"user","source":"body","typeRef":{"kind":"named","value":"User"}}],"path":"/users","returnIsOptional":false,"returnType":{"kind":"named","value":"User"}}],"enums":{"UserRole":{"doc":null,"name":"UserRole","values":["admin","user"]}},"models":{"User":{"doc":"Usage docs: https://docs.pydantic.dev/2.10/concepts/models/\n\nA base class for creating Pydantic models.\n\nAttributes:\n    __class_vars__: The names of the class variables defined on the model.\n    __private_attributes__: Metadata about the private attributes of the model.\n    __signature__: The synthesized `__init__` [`Signature`][inspect.Signature] of the model.\n\n    __pydantic_complete__: Whether model building is completed, or if there are still undefined fields.\n    __pydantic_core_schema__: The core schema of the model.\n    __pydantic_custom_init__: Whether the model has a custom `__init__` function.\n    __pydantic_decorators__: Metadata containing the decorators defined on the model.\n        This replaces `Model.__validators__` and `Model.__root_validators__` from Pydantic V1.\n    __pydantic_generic_metadata__: Metadata for generic models; contains data used for a similar purpose to\n        __args__, __origin__, __parameters__ in typing-module generics. May eventually be replaced by these.\n    __pydantic_parent_namespace__: Parent namespace of the model, used for automatic rebuilding of models.\n    __pydantic_post_init__: The name of the post-init method for the model, if defined.\n    __pydantic_root_model__: Whether the model is a [`RootModel`][pydantic.root_model.RootModel].\n    __pydantic_serializer__: The `pydantic-core` `SchemaSerializer` used to dump instances of the model.\n    __pydantic_validator__: The `pydantic-core` `SchemaValidator` used to validate instances of the model.\n\n    __pydantic_fields__: A dictionary of field names and their corresponding [`FieldInfo`][pydantic.fields.FieldInfo] objects.\n    __pydantic_computed_fields__: A dictionary of computed field names and their corresponding [`ComputedFieldInfo`][pydantic.fields.ComputedFieldInfo] objects.\n\n    __pydantic_extra__: A dictionary containing extra values, if [`extra`][pydantic.config.ConfigDict.extra]\n        is set to `'allow'`.\n    __pydantic_fields_set__: The names of fields explicitly set during instantiation.\n    __pydantic_private__: Values of private attributes set on the model instance.","fields":[{"doc":null,"isOptional":false,"name":"id","typeRef":{"kind":"int64"}},{"doc":null,"isOptional":false,"name":"name","typeRef":{"kind":"string"}},{"doc":null,"isOptional":true,"name":"role","typeRef":{"kind":"named","value":"UserRole"}},{"doc":null,"isOptional":false,"name":"email","typeRef":{"kind":"string"}}],"name":"User"}},"offlineConfig":null,"serviceName":"app","specVersion":"1.0.0","target":null},"policies":null,"project":{"codec":"json","project_id":"python-example","schema_hash":"19b9c116af317a4e13b1a241d59088829d9af453a1a7bcb37054ab7184dc5381","variant":"default","version":"v0.1.4"},"schema_fbs":null,"validators":{"User":"properties:\n  email:\n    email: true\n    type: string\n  role:\n    options:\n    - type: enum\n      values:\n      - admin\n      - user\n    type: union\ntype: object\n"}}